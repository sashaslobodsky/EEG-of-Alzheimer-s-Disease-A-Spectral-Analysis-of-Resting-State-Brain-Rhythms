# Imports
import os
from pathlib import Path
import pandas as pd
import mne
import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np
from scipy.signal import coherence

# Dataset root
DATASET_ROOT = DATASET_ROOT = Path("Data/COGS118C_FINALPRJ")
print("Dataset root:", DATASET_ROOT)

# Load participants
participants = pd.read_csv(DATASET_ROOT / "participants.tsv", sep="\t")

print(participants.columns)
print(participants["Group"].value_counts())

# Separate groups
ad_subjects = participants[participants["Group"] == "A"]
hc_subjects = participants[participants["Group"] == "C"]

print("Alzheimer Subjects:", len(ad_subjects))
print("Healthy Subjects:", len(hc_subjects))

# Sample 20 from each
ad_sample = ad_subjects.sample(20, random_state=42)#random_state included so that it produces same random result so that results can become reproducible
hc_sample = hc_subjects.sample(20, random_state=42)

selected_subjects = pd.concat([ad_sample, hc_sample])
subject_ids = selected_subjects["participant_id"].tolist()

print(subject_ids[:10])

results = []
all_psd = []
ad_coherence = []
hc_coherence = []
#Creating function to calculate alpha band coherence matrix
def compute_alpha_coherence_matrix(raw):
    data = raw.get_data() #Extract EEG data
    sfreq = raw.info['sfreq'] #Sampling rate
    n_channel = data.shape[0]
    #Creating an empty coherence matrix
    coh_matrix = np.zeros((n_channel, n_channel))
    #This for loop will go through the channels examing i
    for i in range(n_channel):
        coh_matrix[i,i] = 1.0
        #This for loop will now compare the channels
        #Channel i vs channel j
        for j in range (i+1, n_channel): #doing i+1 since the matrix is symmetric so you only need to compute half of it 
            #computing the magnitude squared coherence btwn 2 signals
            #f is frequency values, and Cxy is the coherence at each of those frequency
            f, Cxy = coherence(data[i], data[j], fs=sfreq,nperseg=1024)
            alpha_mask = (f>=8) & (f<13)
            alpha_coh = Cxy[alpha_mask].mean()
            #filling the matrix
            coh_matrix[i,j]= alpha_coh
            coh_matrix[j,i]= alpha_coh 
    return coh_matrix
#Looping through each participant ID
for subject in subject_ids:
    try:
        #Making sure folders are downloaded properly and loaded
        eeg_folder = DATASET_ROOT / "derivatives" / subject / "eeg"
        print("Checking folder:", eeg_folder)

        if not eeg_folder.exists():
            print("Folder not found:", eeg_folder)
            continue

        eeg_files = [f for f in os.listdir(eeg_folder) if f.endswith(".set")]
        print("Found files:", eeg_files)

        if len(eeg_files) == 0:
            print("No .set file found for", subject)
            continue

        file_path = eeg_folder / eeg_files[0]

        raw = mne.io.read_raw_eeglab(file_path, preload=True)
        print("Loaded:", subject)
    

        # Preprocess
        raw.filter(0.5, 40.0)
        raw.notch_filter(50.0)
        raw.set_eeg_reference("average")

        # Compute PSD with Welch
        data = raw.get_data()
        sfreq = raw.info["sfreq"]

        psd, freqs = mne.time_frequency.psd_array_welch(
            data,
            sfreq=sfreq,
            fmin=0.5,
            fmax=40.0,
            n_fft=1024
        )

        # Average PSD across channels and frequencies in each band
        delta = psd[:, (freqs >= 1) & (freqs < 4)].mean()
        theta = psd[:, (freqs >= 4) & (freqs < 8)].mean()
        alpha = psd[:, (freqs >= 8) & (freqs < 13)].mean()
        beta = psd[:, (freqs >= 13) & (freqs < 30)].mean()

        group = participants.loc[
            participants["participant_id"] == subject, "Group"
        ].values[0]

        all_psd.append(psd.mean(axis=0))
        results.append({
            "participant_id": subject,
            "group": group,
            "delta": delta,
            "theta": theta,
            "alpha": alpha,
            "beta": beta
        })
        #Calling function from before and defing it as coh_matrix - Computes coherence between each electrode pair
        coh_matrix = compute_alpha_coherence_matrix(raw)
        #Now just stroring it by group AD and Healthy
        if group == "A":
            ad_coherence.append(coh_matrix)
        elif group == "C":
            hc_coherence.append(coh_matrix)

        print("Processed:", subject)
    #handles if something is missing or failed to run
    except Exception as e:
        print(f"Skipping {subject} due to error: {e}")
        continue

# Convert to dataframe
results_df = pd.DataFrame(results)
psd_array = np.array(all_psd)
print(results_df.head())
if results_df.empty:
    raise ValueError("No subjects were processed successfully. Check EEG folder path and dataset structure.")
print(results_df.groupby("group")[["delta", "theta", "alpha", "beta"]].mean())
print('AD coherence matrices:', len(ad_coherence))
print('HC coherence matrices:', len(hc_coherence))

#Creating Vizualization 1 - Bar Plot

bands = ['delta','theta','alpha','beta']
#using the melt function so that we can just easily plot mulitple frequency bands in one graph without doing multiple so that its cleaner 
#the melt function will reshape the df from a wide format to long so seaborn can easily compare the categories
results_melt = results_df.melt(
    id_vars = 'group',
    value_vars = bands,
    var_name = 'band',
    value_name = 'power',
)

sns.barplot(
    data = results_melt,
    x='band',
    y = 'power',
    hue='group',
    palette = {'A': '#384860','C':'#97A6C4'},
    errorbar='se' #Chose error bar of standard error instead of standard deviation because se looked cleaner and also because I wanted to measure the uncertainty in the mean estimate rather than distribution variability
)

plt.title('Average EEG Band Power AD vs Healthy')
plt.xlabel('Frequency Band')
plt.ylabel('Power')
plt.show()

#Creating Visualization #2 - A Power Spectrum Overlay

# plotting averages across the PSDs
ad_mask = results_df["group"].to_numpy() == "A"
hc_mask = results_df["group"].to_numpy() == "C"
ad_group = psd_array[ad_mask]
hc_group = psd_array[hc_mask]
ad_mean = ad_group.mean(axis=0)
hc_mean = hc_group.mean(axis=0)
ad_se = ad_group.std(axis=0) / np.sqrt(ad_group.shape[0])
hc_se = hc_group.std(axis=0) / np.sqrt(hc_group.shape[0])
ad_lower = np.maximum(ad_mean - ad_se, 1e-20)
hc_lower = np.maximum(hc_mean - hc_se, 1e-20)

plt.figure(figsize=(8, 5))

plt.plot(freqs, ad_mean, label="Alzheimer's", linewidth=3, alpha=0.8)
plt.fill_between(freqs, ad_lower, ad_mean + ad_se, alpha=0.2)

plt.plot(freqs, hc_mean, label="Healthy", linewidth=2, alpha=0.8)
plt.fill_between(freqs, hc_lower, hc_mean + hc_se, alpha=0.2)

plt.yscale("log")
plt.xlabel("Frequency (Hz)")
plt.ylabel("Power")
plt.title("Log Power Spectrum: AD vs Healthy")
plt.legend()
plt.tight_layout()
plt.show()


#Visualization #3 - Magnitude-Squared Coherence Matrix Graph
#Magnitude-Squared coherence will measure how strongly two EEG channels are related at a frequecny and if its value is near 0 then it will have weak relationship, if value near 1 it has strong relationship 
ad_coh_mean = np.mean(ad_coherence, axis=0)
hc_coh_mean = np.mean(hc_coherence, axis=0)
diff_coh = ad_coh_mean - hc_coh_mean

#Plot heatmap
mask = np.triu(np.ones_like(diff_coh, dtype=bool)) #removes the duplicate half of the matrix since it is symmetric
sns.heatmap(
    diff_coh,
    mask = mask,
    xticklabels=raw.ch_names,
    yticklabels=raw.ch_names,
    cmap="coolwarm",
    center=0,
    vmin=-0.2,#vmin and max creates a fixed limit to the color scale so that it doesn't exaggerate small differences -- this was recommended
    vmax=0.2
)
plt.title("Alpha-Band Coherence Difference (AD - Healthy)")
plt.xlabel("Channel")
plt.ylabel("Channel")
plt.tight_layout()
plt.show()